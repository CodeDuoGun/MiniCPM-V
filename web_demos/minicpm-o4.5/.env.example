MODEL_ID=openbmb/MiniCPM-o-4_5
DEVICE=cuda:0
TORCH_DTYPE=bfloat16
ATTN_IMPLEMENTATION=sdpa
LOAD_MODEL=true
MODEL_MODE=duplex
PORT=32560
LOG_LEVEL=INFO
MAX_ACTIVE_SESSIONS=1
SESSION_IDLE_SECONDS=900
MAX_TURN_AUDIO_SECONDS=120

# Empty means base model only. A 2.6 adapter is not compatible with 4.5.
LORA_ADAPTER=
MERGE_LORA=true

# Reference voice. Use an authorized, clean, 16 kHz mono recording only.
REF_AUDIO_PATH=assets/ref_audios/Wuweiping_test3_ref_16k_mono.wav

SLOT_CONFIG=data/slots/doctor_wuweiping.json
SLOT_HISTORY_TURNS=12
SLOT_LLM_BASE_URL=
SLOT_LLM_API_KEY=
SLOT_LLM_MODEL=
SLOT_ASR_API_KEY=
SLOT_ASR_MODEL=paraformer-realtime-v2
SLOT_ASR_WS_URL=
SLOT_ASR_VOCABULARY_ID=

# OpenAI-compatible VLM used for the quality gate and structured image analysis.
VISION_VLM_BASE_URL=
VISION_VLM_API_KEY=
VISION_VLM_MODEL=

# One readable JSON document is stored locally per consultation. Zero TTL keeps it indefinitely.
CONSULTATION_STORE_DIR=web_demos/minicpm-o4.5/runtime_data/consultations
CONSULTATION_TTL_SECONDS=0

# Images are uploaded under <prefix>/<consultation_id>/<scene>/<uuid>.<ext>.
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET_NAME=
QINIU_BUCKET_DOMAIN=
QINIU_KEY_PREFIX=minicpmo45/consultations

# 0 disables the new model, 1-99 enables deterministic percentage rollout, 100 enables all.
ROLLOUT_PERCENT=0
ROLLOUT_SALT=change-me-before-production

# Patient media retention. Zero removes session media when the session closes.
MEDIA_RETENTION_HOURS=0
LOG_ROOT=web_demos/minicpm-o4.5/runtime_logs
